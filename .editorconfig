root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
tab_width = 8

[*.{nix,ts,mts,cts,js,mjs,cjs,jsx,tsx,css}]
indent_size = 2
indent_style = space

[*.{rs,qml,cpp,h,xml,ui}]
indent_size = 4
indent_style = space

[*.{yaml,toml,json,jsonc}]
indent_size = 2
indent_style = space

[*.{md}]
indent_size = 4
indent_style = space

[{justfile,.justfile}]
indent_size = 4
indent_style = space

[*.{sh,bash,fish,zsh,nu}]
indent_size = 4
indent_style = space

[.{env,envrc}]
indent_size = 4
indent_style = space

[.{env,envrc}.*]
indent_size = 4
indent_style = space
