#!/usr/bin/env -S just --justfile
# SPDX-FileCopyrightText: 2026 KIM Hyunjae
# SPDX-License-Identifier: AGPL-3.0-or-later

set unstable
set fallback
set lazy
set ignore-comments

system := `nix eval --impure --expr builtins.currentSystem`

root := "path:../.."
check_prefix := root + "#checks." + system + "."

_:
    @just --list

[group('build')]
build:
    nix build "{{ root }}#sample" --no-link --print-out-paths

[group('ci')]
check:
    nix build \
        "{{ check_prefix }}sample-typecheck" \
        "{{ check_prefix }}sample-lint" \
        "{{ check_prefix }}sample-kpackage" \
        --no-link --print-out-paths

[group('ci')]
test:
    nix build "{{ check_prefix }}sample-test" --no-link --print-out-paths
