#!/usr/bin/env -S just --justfile
# SPDX-FileCopyrightText: 2026 KIM Hyunjae
# SPDX-License-Identifier: AGPL-3.0-or-later

set unstable
set fallback
set lazy
set ignore-comments

system := `nix eval --impure --expr builtins.currentSystem`

root := "path:../.."
check_prefix := root + "#checks." + system + "."

_:
    @just --list

[group('build')]
build:
    nix build "{{ root }}#tab-pager" --no-link --print-out-paths

[group('build')]
hello:
    "$(nix build "{{ root }}#tab-pager" --no-link --print-out-paths)/bin/tab-pager-hello"

[group('ci')]
check:
    nix build "{{ check_prefix }}tab-pager-check" --no-link --print-out-paths

[group('lint')]
lint:
    nix develop "{{ root }}#tab-pager" -c tab-pager-lint

[group('lint')]
lint-qml:
    nix develop "{{ root }}#tab-pager" -c lint-qml

[group('lint')]
lint-clang-tidy:
    nix develop "{{ root }}#tab-pager" -c lint-clang-tidy

[group('lint')]
lint-clazy:
    nix develop "{{ root }}#tab-pager" -c lint-clazy

[group('test')]
test:
    nix develop "{{ root }}#tab-pager" -c tab-pager-test
