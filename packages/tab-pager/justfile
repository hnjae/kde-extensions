#!/usr/bin/env -S just --justfile

set unstable
set fallback
set lazy
set ignore-comments

system := `nix eval --raw --impure --expr builtins.currentSystem`

root := "path:../.."
check_prefix := root + "#checks." + system + "."
dev_shell := root + "#default"

_:
    @just --list

[group('build')]
build:
    nix build "{{ root }}#tab-pager" --no-link --print-out-paths

[group('ci')]
check:
    nix build "{{ check_prefix }}tab-pager-check" --no-link --print-out-paths

[group('lint')]
lint:
    nix develop "{{ dev_shell }}" -c tab-pager-lint

[group('lint')]
lint-qml:
    nix develop "{{ dev_shell }}" -c tab-pager-lint-qml

[group('lint')]
lint-clang-tidy:
    nix develop "{{ dev_shell }}" -c tab-pager-lint-clang-tidy

[group('lint')]
lint-clazy:
    nix develop "{{ dev_shell }}" -c tab-pager-lint-clazy

[group('test')]
test:
    nix develop "{{ dev_shell }}" -c tab-pager-test
