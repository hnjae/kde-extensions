#!/usr/bin/env -S just --justfile

set unstable
set fallback
set lazy
set ignore-comments

system := `nix eval --raw --impure --expr builtins.currentSystem`

package := "kwin-ime-refocus"
root := "path:../.."
dev_shell := root + "#default"
check_attr := root + "#checks." + system + "." + package + "-check"

_:
    @just --list

[group('build')]
build:
    nix build "{{ dev_shell }}" --no-link --print-out-paths

[group('ci')]
check:
    nix build "{{ check_attr }}" --no-link --print-out-paths

[group('build')]
build-source:
    nix develop "{{ dev_shell }}" -c tsc --project tsconfig.json --outFile build/src/main.js
    nix develop "{{ dev_shell }}" -c node scripts/build-package.mjs

[group('build')]
build-kpackage:
    nix develop "{{ dev_shell }}" -c kwin-ime-refocus-build-kpackage

[group('build')]
check-kpackage: build-source
    nix develop "{{ dev_shell }}" -c node scripts/check-kpackage.mjs

[group('cleanup')]
clean:
    rm -rf build build-tests dist

[group('ci')]
check-local:
    nix develop "{{ dev_shell }}" -c tsc --noEmit --project tsconfig.json
    nix develop "{{ dev_shell }}" -c tsc --noEmit --project tests/tsconfig.json
    nix develop "{{ dev_shell }}" -c biome ci --config-path ../../biome.json kpackage.json package.json scripts src tests tsconfig.json
    nix develop "{{ dev_shell }}" -c tsc --project tsconfig.json --outFile build/src/main.js
    nix develop "{{ dev_shell }}" -c node scripts/build-package.mjs
    nix develop "{{ dev_shell }}" -c node scripts/check-kpackage.mjs
    nix develop "{{ dev_shell }}" -c tsc --project tests/tsconfig.json
    nix develop "{{ dev_shell }}" -c node --test build-tests/*.test.js

[group('lint')]
lint: typecheck
    nix develop "{{ dev_shell }}" -c biome ci --config-path ../../biome.json kpackage.json package.json scripts src tests tsconfig.json

[group('lint')]
typecheck:
    nix develop "{{ dev_shell }}" -c tsc --noEmit --project tsconfig.json
    nix develop "{{ dev_shell }}" -c tsc --noEmit --project tests/tsconfig.json

[group('test')]
test: build-source
    nix develop "{{ dev_shell }}" -c tsc --project tests/tsconfig.json
    nix develop "{{ dev_shell }}" -c node --test build-tests/*.test.js
