#!/usr/bin/env -S just --justfile

set unstable
set fallback
set lazy
set ignore-comments

system := `nix eval --impure --expr builtins.currentSystem`

root := "path:../.."
check_prefix := root + "#checks." + system + "."

_:
    @just --list

[group('build')]
build:
    nix build "{{ root }}#kwin-run-or-raise" --no-link --print-out-paths

[group('ci')]
check:
    nix build "{{ check_prefix }}kwin-run-or-raise-check" --no-link --print-out-paths

[group('lint')]
lint:
    nix develop "{{ root }}#kwin-run-or-raise" -c npm run typecheck
    nix develop "{{ root }}#kwin-run-or-raise" -c npm run lint

[group('test')]
test:
    nix develop "{{ root }}#kwin-run-or-raise" -c npm test
