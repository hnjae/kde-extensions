#!/usr/bin/env -S just --justfile

set unstable
set fallback
set lazy
set ignore-comments

system := `nix eval --raw --impure --expr builtins.currentSystem`

root := "path:../.."
check_prefix := root + "#checks." + system + "."
dev_shell := root + "#default"

_:
    @just --list

[group('build')]
build:
    nix build "{{ root }}#numbered-task-manager" --no-link --print-out-paths

[group('ci')]
check:
    nix build "{{ check_prefix }}numbered-task-manager-check" --no-link --print-out-paths

[group('test')]
test:
    nix develop "{{ dev_shell }}" -c numbered-task-manager-test

[group('test')]
test-host:
    for test_file in tests/*.test.mjs; do node "$test_file"; done

[group('lint')]
lint:
    nix develop "{{ dev_shell }}" -c numbered-task-manager-lint

[group('lint')]
lint-host: lint-js-host

[group('lint')]
lint-js:
    nix develop "{{ dev_shell }}" -c numbered-task-manager-lint-js

[group('lint')]
lint-js-host:
    if command -v biome >/dev/null 2>&1; then \
        biome lint --error-on-warnings package/contents/ui/*.mjs tests/*.mjs; \
    else \
        npx -y @biomejs/biome@2.4.15 lint --error-on-warnings package/contents/ui/*.mjs tests/*.mjs; \
    fi

[group('lint')]
lint-qml:
    nix develop "{{ dev_shell }}" -c numbered-task-manager-lint-qml

[group('lint')]
lint-clang-tidy:
    nix develop "{{ dev_shell }}" -c numbered-task-manager-lint-clang-tidy

[group('lint')]
lint-clazy:
    nix develop "{{ dev_shell }}" -c numbered-task-manager-lint-clazy
